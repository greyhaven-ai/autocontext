{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autocontext.dev/schema/artifact.json",
  "title": "Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "actuatorType",
    "scenario",
    "environmentTag",
    "activationState",
    "payloadHash",
    "provenance",
    "promotionHistory",
    "evalRuns"
  ],
  "properties": {
    "schemaVersion": { "$ref": "https://autocontext.dev/schema/shared-defs.json#/$defs/SchemaVersion" },
    "id": { "$ref": "https://autocontext.dev/schema/shared-defs.json#/$defs/Ulid" },
    "actuatorType": { "$ref": "https://autocontext.dev/schema/shared-defs.json#/$defs/ActuatorType" },
    "scenario": { "$ref": "https://autocontext.dev/schema/shared-defs.json#/$defs/Scenario" },
    "environmentTag": { "$ref": "https://autocontext.dev/schema/shared-defs.json#/$defs/EnvironmentTag" },
    "changeSetId": { "$ref": "https://autocontext.dev/schema/shared-defs.json#/$defs/Ulid" },
    "activationState": { "$ref": "https://autocontext.dev/schema/shared-defs.json#/$defs/ActivationState" },
    "payloadHash": { "$ref": "https://autocontext.dev/schema/shared-defs.json#/$defs/ContentHash" },
    "provenance": { "$ref": "https://autocontext.dev/schema/provenance.json" },
    "strategyIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fingerprint", "components", "lineage"],
      "properties": {
        "fingerprint": { "$ref": "https://autocontext.dev/schema/shared-defs.json#/$defs/ContentHash" },
        "payloadHash": { "$ref": "https://autocontext.dev/schema/shared-defs.json#/$defs/ContentHash" },
        "components": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "fingerprint"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "fingerprint": { "$ref": "https://autocontext.dev/schema/shared-defs.json#/$defs/ContentHash" }
            }
          }
        },
        "lineage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["parentFingerprints"],
          "properties": {
            "parentFingerprints": {
              "type": "array",
              "items": { "$ref": "https://autocontext.dev/schema/shared-defs.json#/$defs/ContentHash" }
            }
          }
        },
        "duplicateOf": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "artifactId", "fingerprint", "similarity"],
          "properties": {
            "kind": { "enum": ["exact", "near"] },
            "artifactId": { "$ref": "https://autocontext.dev/schema/shared-defs.json#/$defs/Ulid" },
            "fingerprint": { "$ref": "https://autocontext.dev/schema/shared-defs.json#/$defs/ContentHash" },
            "similarity": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      }
    },
    "strategyQuarantine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reason", "sourceArtifactIds", "sourceFingerprints"],
      "properties": {
        "status": { "const": "quarantined" },
        "reason": { "enum": ["repeated-invalid-strategy", "contaminated-finding"] },
        "sourceArtifactIds": {
          "type": "array",
          "items": { "$ref": "https://autocontext.dev/schema/shared-defs.json#/$defs/Ulid" }
        },
        "sourceFingerprints": {
          "type": "array",
          "items": { "$ref": "https://autocontext.dev/schema/shared-defs.json#/$defs/ContentHash" }
        },
        "detail": { "type": "string", "minLength": 1 }
      }
    },
    "promotionHistory": {
      "type": "array",
      "items": { "$ref": "https://autocontext.dev/schema/promotion-event.json" }
    },
    "evalRuns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["evalRunId", "suiteId", "ingestedAt"],
        "properties": {
          "evalRunId": { "type": "string", "minLength": 1 },
          "suiteId": { "$ref": "https://autocontext.dev/schema/shared-defs.json#/$defs/SuiteId" },
          "ingestedAt": { "$ref": "https://autocontext.dev/schema/shared-defs.json#/$defs/IsoTimestamp" }
        }
      }
    }
  }
}
